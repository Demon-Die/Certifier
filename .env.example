# Required: NextAuth
AUTH_SECRET=<generate with: openssl rand -base64 32>
AUTH_GITHUB_ID=<GitHub OAuth App Client ID>
AUTH_GITHUB_SECRET=<GitHub OAuth App Client Secret>

# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=<Supabase project URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase anon/public key>

# Optional: certifier.io (badge claiming) — Multi-Account Rotation
# Assign a different certifier.io account per family to pool monthly quotas.
# Fill in your actual API keys and template group IDs below.
CERTIFIER_ACCOUNTS='[
  {"family":"frontend", "apiKey":"cfp_YOUR_FRONTEND_KEY", "templates":{"imp":"grp_FRONTEND_IMP","fiend":"grp_FRONTEND_FIEND","overlord":"grp_FRONTEND_OVERLORD","demon king":"grp_FRONTEND_DEMONKING"}},
  {"family":"backend",  "apiKey":"cfp_YOUR_BACKEND_KEY",  "templates":{"imp":"grp_BACKEND_IMP","fiend":"grp_BACKEND_FIEND","overlord":"grp_BACKEND_OVERLORD","demon king":"grp_BACKEND_DEMONKING"}},
  {"family":"docs",     "apiKey":"cfp_YOUR_DOCS_KEY",     "templates":{"imp":"grp_DOCS_IMP","fiend":"grp_DOCS_FIEND","overlord":"grp_DOCS_OVERLORD","demon king":"grp_DOCS_DEMONKING"}},
  {"family":"ideas",    "apiKey":"cfp_YOUR_IDEAS_KEY",    "templates":{"imp":"grp_IDEAS_IMP","fiend":"grp_IDEAS_FIEND","overlord":"grp_IDEAS_OVERLORD","demon king":"grp_IDEAS_DEMONKING"}},
  {"family":"community","apiKey":"cfp_YOUR_COMMUNITY_KEY","templates":{"imp":"grp_COMMUNITY_IMP","fiend":"grp_COMMUNITY_FIEND","overlord":"grp_COMMUNITY_OVERLORD","demon king":"grp_COMMUNITY_DEMONKING"}}
]'

# Required for GitHub webhook
# Set this in your Vercel/ hosting environment
# WEBHOOK_SECRET is stored in DB via admin settings page
