# Required: NextAuth
AUTH_SECRET=<generate with: openssl rand -base64 32>
AUTH_GITHUB_ID=<GitHub OAuth App Client ID>
AUTH_GITHUB_SECRET=<GitHub OAuth App Client Secret>

# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=<Supabase project URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase anon/public key>

# Optional: certifier.io (badge claiming)
#
# NEW (recommended): Multi-account config — assign a different certifier.io account
# per family to pool monthly credential quotas. Each account only needs 4 templates
# (the 4 tiers for its family). Set a single JSON array:
#
# CERTIFIER_ACCOUNTS='[
#   {"family":"frontend","apiKey":"cfp_xxx...","templates":{"imp":"grp1","fiend":"grp2","overlord":"grp3","demon king":"grp4"}},
#   {"family":"backend", "apiKey":"cfp_yyy...","templates":{"imp":"grp5","fiend":"grp6","overlord":"grp7","demon king":"grp8"}},
#   {"family":"docs",    "apiKey":"cfp_zzz...","templates":{...}},
#   {"family":"ideas",   "apiKey":"cfp_www...","templates":{...}},
#   {"family":"community","apiKey":"cfp_vvv...","templates":{...}}
# ]'
#
# LEGACY (still supported): Single account config
# CERTIFIER_API_KEY=<Certifier API access token>
# CERTIFIER_TEMPLATES='{"frontend:imp":"grp_xxx","frontend:fiend":"grp_yyy",...}'
# 5 families × 4 tiers = 20 entries in old format
CERTIFIER_ACCOUNTS='[]'

# Required for GitHub webhook
# Set this in your Vercel/ hosting environment
# WEBHOOK_SECRET is stored in DB via admin settings page
